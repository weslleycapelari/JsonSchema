#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_PATH="$REPO_ROOT/scripts/Convert-PasToWindows1252.ps1"

if command -v pwsh > /dev/null 2>&1; then
  POWERSHELL_CMD="pwsh"
elif command -v powershell > /dev/null 2>&1; then
  POWERSHELL_CMD="powershell"
else
  echo "ERROR: PowerShell was not found. Install pwsh or powershell to run pre-commit checks."
  exit 1
fi

"$POWERSHELL_CMD" -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_PATH" -RootPath "$REPO_ROOT" -StageChanges
